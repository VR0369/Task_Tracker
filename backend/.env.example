# ============================================================================
# Task Tracker — backend environment
# Copy to `.env`. Everything below has safe defaults for local mock mode.
# ============================================================================

ENVIRONMENT=development
DEBUG=true
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost

# --- Database -------------------------------------------------------------
# MOCK_DB=true  -> in-memory database, no MongoDB required (great for a demo).
# MOCK_DB=false -> use the MONGO_URL below (docker-compose provides one).
MOCK_DB=true
MONGO_URL=mongodb://mongo:27017
MONGO_DB_NAME=task_tracker
SEED_ON_STARTUP=true

# --- JWT ------------------------------------------------------------------
JWT_SECRET=CHANGE_ME_super_secret_dev_key_do_not_use_in_prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# --- Google OAuth ---------------------------------------------------------
# MOCK_AUTH=true enables the /auth/dev-login shortcut and accepts a fake
# "mock:email:name" id_token. Set false + fill the client id/secret to go live.
MOCK_AUTH=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback

# --- AccuWeather ----------------------------------------------------------
MOCK_WEATHER=true
ACCUWEATHER_API_KEY=

# --- On This Day ----------------------------------------------------------
MOCK_HISTORY=true
