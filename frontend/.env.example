# Base URL of the FastAPI backend. In dev, the Vite proxy forwards /api to
# http://localhost:8000, so the default below works out of the box.
VITE_API_BASE_URL=/api/v1

# Optional: your Google OAuth client id (only needed when the backend runs
# with MOCK_AUTH=false). Leave blank to use the mock/dev login.
VITE_GOOGLE_CLIENT_ID=
