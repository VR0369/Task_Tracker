# Copy to `.env`. All values have working defaults for local dev mode.

# Base URL the browser hits. Dev (Vite) = 5173, Docker compose = 8080.
E2E_BASE_URL=http://localhost:5173

# Where the backend API lives. Defaults to `${E2E_BASE_URL}/api/v1`
# (Vite proxies /api to the backend, so the default works in dev).
# Point straight at the backend if you skip the proxy: http://localhost:8000/api/v1
E2E_API_BASE_URL=

# Email used for the seeded/authenticated E2E user (MOCK_AUTH dev-login).
E2E_USER_EMAIL=e2e@example.com

# Set to 1 to NOT auto-start the backend/frontend from Playwright.
# Use this when running against Docker (E2E_BASE_URL=http://localhost:8080)
# or servers you started yourself.
E2E_NO_WEBSERVER=

# JWT secret passed to the auto-started backend (must be non-empty).
JWT_SECRET=e2e_dev_secret_change_me
